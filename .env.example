# Copie para .env e preencha. O .env está no .gitignore — NUNCA commite o token.

# DNS da conta (usuário do Basic Auth). Geralmente "evo".
EVO_DNS=evo

# Token da API do EVO (senha do Basic Auth). NÃO commitar.
EVO_TOKEN=coloque_seu_token_aqui

# Protege o endpoint MCP colocando um segredo no caminho da URL.
# Se definido, o endpoint vira /mcp/<MCP_SECRET> (só quem tem a URL conecta).
# Vazio = endpoint público em /mcp. Use um valor longo e aleatório.
# MCP_SECRET=troque-por-um-valor-aleatorio-longo

# Opcionais
# EVO_BASE_URL=https://evo-integracao.w12app.com.br
# EVO_HTTP_TIMEOUT=60
# PORT=8000
